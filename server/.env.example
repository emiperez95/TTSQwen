# TTSQwen Server Configuration
# Copy to .env and modify as needed: cp .env.example .env

# ─── Models ───
# HuggingFace model IDs (downloaded automatically on first run)
# SUMMARIZER_MODEL=Qwen/Qwen3-1.7B
# TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# TTS_MODEL_BASE=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# ─── TTS Defaults ───
# Default voice for preset speaker mode
# TTS_VOICE=Aiden
# TTS_LANGUAGE=English
# TTS_INSTRUCT=
# TTS_SPEED=1.0

# ─── Model Management ───
# Seconds of idle time before unloading a GPU model (0 = never unload)
# MODEL_IDLE_TIMEOUT=120

# ─── Server ───
# HOST=0.0.0.0
# PORT=9800
# CORS_ORIGINS=*                  # Comma-separated origins, or * for all
